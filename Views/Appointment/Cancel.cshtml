@model HPMS.Models.Appointment

@{
    ViewData["Title"] = "Cancel Appointment";
}

<h1>Cancel Appointment</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to cancel this appointment?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Appointment #</dt>
        <dd class="col-sm-10">@Model.AppointmentNumber</dd>

        <dt class="col-sm-2">Patient</dt>
        <dd class="col-sm-10">@Model.Patient?.FullName</dd>

        <dt class="col-sm-2">Doctor</dt>
        <dd class="col-sm-10">@Model.Doctor?.User?.FullName</dd>

        <dt class="col-sm-2">Date & Time</dt>
        <dd class="col-sm-10">@Model.AppointmentDateTime.ToString("yyyy-MM-dd HH:mm")</dd>

        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.Type</dd>

        <dt class="col-sm-2">Reason</dt>
        <dd class="col-sm-10">@Model.Reason</dd>
    </dl>

    <form asp-action="Cancel">
        <input type="hidden" asp-for="AppointmentId" />
        <input type="submit" value="Confirm Cancel" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>