@model HPMS.Models.Appointment

@{
    ViewData["Title"] = "Schedule Appointment";
}

<h1>Schedule New Appointment</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label class="control-label">Select Patient</label>
        <select asp-for="PatientId" class="form-control" asp-items="ViewBag.PatientList">
            <option value="">-- Select Patient --</option>
        </select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="AppointmentDateTime" class="control-label">Select Date & Time</label>
        <input asp-for="AppointmentDateTime" class="form-control" type="datetime-local" />
        <span asp-validation-for="AppointmentDateTime" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label class="control-label">Select Doctor</label>
        <select asp-for="DoctorId" class="form-control" asp-items="ViewBag.DoctorList">
            <option value="">-- Select Doctor --</option>
        </select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Type" class="control-label"></label>
        <select asp-for="Type" class="form-control">
            <option value="Regular">Regular</option>
            <option value="Emergency">Emergency</option>
            <option value="FollowUp">Follow Up</option>
            <option value="Consultation">Consultation</option>
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Reason" class="control-label"></label>
        <textarea asp-for="Reason" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Reason" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Symptoms" class="control-label"></label>
        <textarea asp-for="Symptoms" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Symptoms" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Schedule Appointment" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}