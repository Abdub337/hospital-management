@model HPMS.Models.Patient

@{
    ViewData["Title"] = "Delete Patient";
}

<h1>Delete Patient</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this patient?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Patient Number</dt>
        <dd class="col-sm-10">@Model.PatientNumber</dd>

        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@Model.FullName</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="PatientId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>