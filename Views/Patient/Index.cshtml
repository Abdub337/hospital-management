@model IEnumerable<HPMS.Models.Patient>

@{
    ViewData["Title"] = "Patient List";
}

<h1>Patient List</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Search" method="get" class="d-flex">
            <input type="text" name="searchTerm" class="form-control me-2" placeholder="Search by name, patient number, phone, or email..." value="@ViewBag.SearchTerm" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Clear</a>
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Register" class="btn btn-primary">Register New Patient</a>
    </div>
</div>

@if (ViewBag.SearchResultCount != null)
{
    <div class="alert alert-info">
        Found @ViewBag.SearchResultCount patient(s) matching your search.
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Patient Number</th>
            <th>Full Name</th>
            <th>Date of Birth</th>
            <th>Gender</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Actions</th>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center">No patients found. Click "Register New Patient" to add one.</td>
            </tr>
        }
        else
        {
            @foreach (var patient in Model)
            {
                <tr>
                    <td>@patient.PatientNumber</td>
                    <td>@patient.FullName</td>
                    <td>@patient.DateOfBirth.ToShortDateString()</td>
                    <td>@patient.Gender</td>
                    <td>@patient.Phone</td>
                    <td>@patient.Email</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@patient.PatientId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@patient.PatientId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@patient.PatientId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>