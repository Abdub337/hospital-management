@model HPMS.Models.Doctor

@{
    ViewData["Title"] = "Delete Doctor";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title">Delete Doctor</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h4>Are you sure you want to delete this doctor?</h4>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["Error"]
                        </div>
                    }

                    <table class="table table-bordered">
                        <tr>
                            <th>Doctor Number</th>
                            <td>@Model.DoctorNumber</td>
                        </tr>
                        <tr>
                            <th>Full Name</th>
                            <td>@Model.User?.FullName</td>
                        </tr>
                        <tr>
                            <th>Specialization</th>
                            <td>@Model.Specialization</td>
                        </tr>
                        <tr>
                            <th>License Number</th>
                            <td>@Model.LicenseNumber</td>
                        </tr>
                        <tr>
                            <th>Consultation Fee</th>
                            <td>@Model.ConsultationFee.ToString("C")</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>
                                @if (Model.IsAvailable)
                                {
                                    <span style="color: green;">Available</span>
                                }
                                else
                                {
                                    <span style="color: red;">Unavailable</span>
                                }
                            </td>
                        </tr>
                    </table>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="DoctorId" />
                        <div class="text-center">
                            <button type="submit" class="btn btn-danger">Confirm Delete</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>