@{
    ViewData["Title"] = "Reports";
}

<h1>Generate Reports</h1>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4>Patient Reports</h4>
            </div>
            <div class="card-body">
                <form asp-action="PatientReport" method="get">
                    <div class="form-group">
                        <label>From Date</label>
                        <input type="date" name="fromDate" class="form-control" value="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group mt-3">
                        <label>To Date</label>
                        <input type="date" name="toDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <button type="submit" class="btn btn-primary mt-3">Generate Patient Report (PDF)</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4>Appointment Reports</h4>
            </div>
            <div class="card-body">
                <form asp-action="AppointmentReport" method="get">
                    <div class="form-group">
                        <label>From Date</label>
                        <input type="date" name="fromDate" class="form-control" value="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group mt-3">
                        <label>To Date</label>
                        <input type="date" name="toDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <button type="submit" class="btn btn-success mt-3">Generate Appointment Report (PDF)</button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-4">
        @TempData["Success"]
    </div>
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="alert alert-info">
            <strong>Note:</strong> Reports are saved to: <strong>C:\HPMS_Reports\</strong>
        </div>
    </div>
</div>